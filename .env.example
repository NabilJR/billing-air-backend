# Environment Variables
PORT=5000

# Neon DB Connection String
# IMPORTANT: Replace with your actual Neon DB connection string from Neon console
# Get it from: https://console.neon.tech -> Your Project -> Connection Details
DATABASE_URL=postgresql://username:password@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# JWT Secret Key - Generate a strong random string (at least 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars-here

# Server Configuration
NODE_ENV=production

# Frontend URL - for CORS (change to your production URL, no trailing slash)
FRONTEND_URL=https://your-frontend-domain.com
